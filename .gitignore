# Gitignore and local layout — Sprint 030

# Python bytecode
__pycache__/
*.py[cod]

# Virtual environments
.venv/

# Test and quality caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.uv-cache/
.coverage
coverage.xml
htmlcov/

# Build outputs
build/
dist/
*.egg-info/

# Environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
credentials.json

# Legacy / superseded local AWS runbook path (use deploy/local_aws_runbook/)
local_aws_runbook/

# Deploy local runbook payloads (keep README)
deploy/local_aws_runbook/**
!deploy/local_aws_runbook/
!deploy/local_aws_runbook/README.md

# User-owned research and data
user_data/**
!user_data/README.md

# Local scratch (bench logs, one-off probes)
scratch/**
!scratch/README.md

# Deprecated root temp names (prefer scratch/)
.tmp_*

# Generated demo HTML
artifacts/demo/**
!artifacts/demo/
!artifacts/README.md
!artifacts/demo/README.md
!artifacts/demo/output/
!artifacts/demo/output/.gitkeep

# Local analytical files outside fixtures
*.duckdb
*.db
*.db-journal

# IDE / agent local tooling
.idea/
.agents/
.codex/

# Cursor local state, but keep project rules
.cursor/*
!.cursor/rules/
!.cursor/rules/**
!.cursor/BUGBOT.md

# Operating system
.DS_Store
Thumbs.db
desktop.ini
